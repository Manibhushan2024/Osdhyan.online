# ─────────────────────────────────────────────
#  OSDHYAN Portal — Environment Configuration
#  Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# Base URL of your Laravel API (no trailing slash, /api suffix required)
# Local:      http://localhost:8000/api
# Production: https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Base URL for user-uploaded media served from Laravel storage
# Local:      http://localhost:8000/storage
# Production: https://api.yourdomain.com/storage
NEXT_PUBLIC_STORAGE_URL=http://localhost:8000/storage

# Site URL (used for og:url, canonical links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry error tracking (leave empty to disable in development)
# Get DSN from: https://sentry.io → Projects → Next.js project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
