APP_NAME="OSDHYAN"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────
DB_CONNECTION=pgsql

# Production (Neon/Railway/Koyeb): paste the full connection string here
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Local dev: individual vars
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=test_series_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer

# ─── Cache & Queue (Redis) ───────────────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ─── Broadcasting ────────────────────────────────────────────────
BROADCAST_DRIVER=log

# ─── Mail (Resend) — https://resend.com ──────────────────────────
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@osdhyan.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# ─── AI Providers ────────────────────────────────────────────────
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── SMS ─────────────────────────────────────────────────────────
SMS_PROVIDER=textlocal
SMS_API_KEY=
SMS_SENDER_ID=OSDHYN

# ─── Google OAuth — https://console.cloud.google.com ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# ─── Sanctum ─────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS="localhost:3000,localhost,127.0.0.1"

# ─── File Storage ────────────────────────────────────────────────
# local = uses storage/app/public (dev)
# r2    = Cloudflare R2 (production — free 10GB)
FILESYSTEM_DISK=local

# Cloudflare R2 — https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=osdhyan-storage
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev  # or your custom domain

# ─── Sentry — https://sentry.io ──────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ─── Laravel Horizon ─────────────────────────────────────────────
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# ─── Production CORS (uncomment and set for production) ──────────
# ALLOWED_ORIGINS=https://osdhyan.com,https://www.osdhyan.com

APP_KEY=
